PORT=8000
CORS_ORIGIN=*
# Set to your public Render URL so merge/download links work from phones
PUBLIC_API_URL=https://zeroads-api.onrender.com

# Optional: Netscape-format YouTube cookies (extra fallback if POT provider fails).
# YTDLP_COOKIES=

# PO token provider (started automatically in Docker — usually no config needed)
YTDLP_POT_PROVIDER_URL=http://127.0.0.1:4416
